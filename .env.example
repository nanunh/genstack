# StackGPT - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --------------------------------------------------
# LLM Provider — set ONE (or both; Anthropic takes priority if both are set)
# You can also force a provider with LLM_PROVIDER=anthropic|gemini
# --------------------------------------------------

# Anthropic (Claude models)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Google Gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: explicitly pick provider (auto-detected from keys if omitted)
# LLM_PROVIDER=anthropic

# Optional: override the model used (defaults shown below)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# GEMINI_MODEL=gemini-2.0-flash

# --------------------------------------------------
# Server Configuration
# --------------------------------------------------
SERVER_URL=https://localhost:8000
LOG_LEVEL=INFO

# --------------------------------------------------
# Output Directory (runtime, auto-created)
# --------------------------------------------------
OUTPUT_DIR=generated_projects

# --------------------------------------------------
# MySQL Database
# --------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stackgpt_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Mail Configuration (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
